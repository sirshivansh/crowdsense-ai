rules_version = '2';

// Firestore Security Rules for CrowdSense AI
// These rules enforce authentication and data structure validation
// for all collections used by the crowd management pipeline.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Crowd density logs ─────────────────────────────────────
    // Written by the simulator heartbeat (3-second cadence).
    // Read by the admin dashboard for historical analysis.
    match /crowdLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['zones', 'timestamp'])
        && request.resource.data.zones is list;
      allow update, delete: if false;
    }

    // ── AI prediction audit logs ───────────────────────────────
    // Written when the AI predictor detects a trend with >60% confidence.
    // Immutable after creation for audit integrity.
    match /predictionLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['timestamp']);
      allow update, delete: if false;
    }

    // ── Active high-density alerts ─────────────────────────────
    // Written when any zone breaches the 85% density threshold.
    // Readable by all authenticated operators for real-time response.
    match /activeAlerts/{alertId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['zoneId', 'zoneName', 'density', 'priority', 'timestamp'])
        && request.resource.data.density is number
        && request.resource.data.priority in ['HIGH', 'MEDIUM', 'LOW'];
      allow update, delete: if false;
    }

    // ── Structured system events (analytics) ───────────────────
    // Captures routing decisions, emergency activations, and prediction audits.
    // Used for post-event analysis and system behavior tracing.
    match /systemEvents/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['type', 'timestamp'])
        && request.resource.data.type is string;
      allow update, delete: if false;
    }

    // ── Default deny ───────────────────────────────────────────
    // All other paths are blocked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
